rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Rules
    match /purposes/{purposeId} {
      allow read: if true; 
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /logs/{logId} {
      // Anyone can create a log
      allow create: if request.resource.data.ownerId != null;

      // Only the owner (admin) can list/read all logs
      // For visitors to "search" their log, we allow a very specific query check
      allow read: if (isAuthenticated() && resource.data.ownerId == request.auth.uid) ||
                     (request.auth == null && 
                      resource.data.visitorName != null && 
                      resource.data.visitorContact != null);

      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if true;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
