rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper to check if user is admin
    function isAuthenticated() {
      return request.auth != null;
    }

    match /logs/{adminId}/{fileName} {
      // Allow visitors to upload images (signatures, photos)
      // We can't easily restrict 'upload only' without auth, but we can restrict read.
      allow write: if true;
      
      // Only the admin who owns the log should be able to read the images
      allow read: if isAuthenticated() && request.auth.uid == adminId;
    }
    
    match /branding/{adminId}/{fileName} {
      // Admins manage their own branding assets
      allow write: if isAuthenticated() && request.auth.uid == adminId;
      // Anyone can read branding assets to see the UI
      allow read: if true;
    }
  }
}
