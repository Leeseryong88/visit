rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) && 
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Rules for visitor logs (signatures, attachments)
    match /logs/{adminId}/{allPaths=**} {
      // Visitors can upload (create) and get download URLs (read)
      allow create: if true;
      allow get: if true;
      // Only admins can list, update or delete
      allow list, update, delete: if isAuthenticated() && (request.auth.uid == adminId || isAdmin());
    }

    // Rules for branding (logos)
    match /branding/{adminId}/{allPaths=**} {
      // Admins can read/write their own branding
      allow read: if true; // Publicly readable for visitors to see the logo
      allow write: if isAuthenticated() && (request.auth.uid == adminId || isAdmin());
    }

    // Rules for notifications
    match /notifications/{adminId}/{allPaths=**} {
      // Publicly readable for visitors to see the notification image
      allow read: if true;
      allow write: if isAuthenticated() && (request.auth.uid == adminId || isAdmin());
    }
  }
}
